<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisionEditCV.Shared.ViewModels"
             xmlns:models="using:VisionEditCV.Shared.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="430" d:DesignHeight="852"
             x:Class="VisionEditCV.Shared.Views.MobileHomeView"
             x:Name="Root"
             x:DataType="vm:LibraryViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *">

    <!-- App bar -->
    <Border Grid.Row="0" Classes="top-bar" Padding="16,12">
      <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Width="30" Height="30" CornerRadius="8"
                  Background="{DynamicResource AccentSoftBrush}"
                  BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1">
            <Path Data="{StaticResource IconLogo}" Width="14" Height="14"
                  Fill="{DynamicResource AccentBrush}" Stretch="Uniform"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="VisionEdit" Classes="h2" FontSize="14" VerticalAlignment="Center" />
        </StackPanel>
        <Button Grid.Column="2" Classes="accent" Height="34" Padding="14,0"
                Command="{Binding NewProjectCommand}" CommandParameter="{Binding #Root}"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Data="M12,5 L12,19 M5,12 L19,12" Width="12" Height="12"
                  Stroke="{DynamicResource OnAccentTextBrush}" StrokeThickness="2.5" Stretch="Uniform" />
            <TextBlock Text="NEW" FontSize="11" FontWeight="Bold" LetterSpacing="0.08" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto" Padding="0,0,0,110">
      <StackPanel>

        <!-- Page header -->
        <StackPanel Margin="18,18,18,18" Spacing="14">
          <Grid ColumnDefinitions="*, Auto">
            <StackPanel Grid.Column="0" Spacing="6">
              <TextBlock Text="{Binding ProjectCountText}" Classes="mono"
                         FontSize="10" LetterSpacing="0.16"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="Library" FontSize="30" FontWeight="Bold" LetterSpacing="-0.025"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
          </Grid>

          <!-- Search box -->
          <Border Classes="composer" Height="40" Padding="14,3,14,3">
            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
              <Path Grid.Column="0" Data="{StaticResource IconSearch}" Width="14" Height="14"
                    Stroke="{DynamicResource TextTertiaryBrush}" StrokeThickness="2"
                    Stretch="Uniform" VerticalAlignment="Center" />
              <TextBox Grid.Column="1" Watermark="Search projects…"
                       Text="{Binding SearchQuery, Mode=TwoWay}"
                       Background="Transparent" BorderThickness="0"
                       VerticalContentAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            </Grid>
          </Border>

          <!-- Filter chip row -->
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <RadioButton Classes="panel-tab" GroupName="MobileFilter" Height="30" MinWidth="60"
                           IsChecked="{Binding IsAllFilter, Mode=OneWay}"
                           Command="{Binding SelectFilterCommand}" CommandParameter="All"
                           Content="All" />
              <RadioButton Classes="panel-tab" GroupName="MobileFilter" Height="30" MinWidth="60"
                           IsChecked="{Binding IsInProgressFilter, Mode=OneWay}"
                           Command="{Binding SelectFilterCommand}" CommandParameter="InProgress"
                           Content="In progress" />
              <RadioButton Classes="panel-tab" GroupName="MobileFilter" Height="30" MinWidth="60"
                           IsChecked="{Binding IsExportedFilter, Mode=OneWay}"
                           Command="{Binding SelectFilterCommand}" CommandParameter="Exported"
                           Content="Exported" />
              <RadioButton Classes="panel-tab" GroupName="MobileFilter" Height="30" MinWidth="60"
                           IsChecked="{Binding IsPinnedFilter, Mode=OneWay}"
                           Command="{Binding SelectFilterCommand}" CommandParameter="Pinned"
                           Content="Pinned" />
            </StackPanel>
          </ScrollViewer>
        </StackPanel>

        <!-- Continue editing rail -->
        <StackPanel IsVisible="{Binding HasRecentProjects}" Margin="0,0,0,26" Spacing="12">
          <TextBlock Margin="18,0" Text="CONTINUE EDITING" Classes="mono"
                     FontSize="10" LetterSpacing="0.16"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                        Padding="18,0">
            <ItemsControl ItemsSource="{Binding RecentProjects}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="12" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:ProjectItem">
                  <Button Classes="card-button" Cursor="Hand"
                          Command="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).OpenProjectCommand}"
                          CommandParameter="{Binding $self}">
                    <Border Width="156" Height="196" CornerRadius="14" ClipToBounds="True"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                            Background="{Binding ThumbBrush}">
                      <Panel>
                        <Border>
                          <Border.Background>
                            <LinearGradientBrush StartPoint="0%,40%" EndPoint="0%,100%">
                              <GradientStop Color="#00000000" Offset="0" />
                              <GradientStop Color="#B3000000" Offset="1" />
                            </LinearGradientBrush>
                          </Border.Background>
                        </Border>
                        <StackPanel VerticalAlignment="Bottom" Margin="14,0,14,14" Spacing="3">
                          <TextBlock Text="{Binding Name}" FontSize="14.5" FontWeight="Bold"
                                     Foreground="White" />
                          <TextBlock Text="{Binding LastEditedText}" Classes="mono"
                                     FontSize="10" LetterSpacing="0.05" Foreground="#B3FFFFFF" />
                        </StackPanel>
                      </Panel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>

        <!-- All projects list -->
        <Grid Margin="18,0,18,12" ColumnDefinitions="*, Auto">
          <TextBlock Grid.Column="0" Text="ALL PROJECTS" Classes="mono"
                     FontSize="10" LetterSpacing="0.16"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <TextBlock Grid.Column="1" Text="{Binding ProjectCountSummary}" Classes="mono"
                     FontSize="10" LetterSpacing="0.04"
                     Foreground="{DynamicResource TextTertiaryBrush}" />
        </Grid>

        <ItemsControl ItemsSource="{Binding Projects}" Margin="18,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="10" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="models:ProjectItem">
              <Button Classes="card-button" Cursor="Hand"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Command="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).OpenProjectCommand}"
                      CommandParameter="{Binding $self}">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                        CornerRadius="14" Padding="12">
                  <Grid ColumnDefinitions="60, *, Auto" ColumnSpacing="14">
                    <Border Grid.Column="0" Width="60" Height="60" CornerRadius="10"
                            Background="{Binding ThumbBrush}" />
                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                      <TextBlock Text="{Binding MetaText}" Classes="mono"
                                 FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                    <Path Grid.Column="2" Data="{StaticResource IconChevronRight}"
                          Width="16" Height="16" VerticalAlignment="Center"
                          Stroke="{DynamicResource TextTertiaryBrush}" StrokeThickness="2"
                          Stretch="Uniform" />
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
