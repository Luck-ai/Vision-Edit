<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VisionEditCV.Shared.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:VisionEditCV.Shared.Controls"
        xmlns:conv="using:VisionEditCV.Shared.Converters"
        xmlns:cp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="VisionEditCV.Shared.Views.MainView"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        
        
        
        
        
        Background="{DynamicResource AppBackgroundBrush}"
        >

    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenImageCommand}" CommandParameter="{Binding #Root}" />
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveImageCommand}" CommandParameter="{Binding #Root}" />
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoEffectCommand}" />
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding SegmentCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding ClearMasksCommand}" />
    </UserControl.KeyBindings>

    <UserControl.Resources>
        <conv:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
        <conv:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <conv:CollectionCountToBoolConverter x:Key="CollectionCountToBoolConverter" />
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        <conv:BoolToDoubleConverter x:Key="BoolToDoubleConverter" />
        <conv:IntEqualsConverter x:Key="IntEqualsConverter" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}" RowDefinitions="Auto, *, Auto">

        <!-- ================================================================
             ZONE 1 · TOP BAR
             Lean composer: brand | tool toggle + prompt + segment | status
             ================================================================ -->
        <Border Grid.Row="0" Classes="top-bar" Padding="20,16,20,12">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">

                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="32" Height="32" CornerRadius="8"
                            Background="{DynamicResource AccentSoftBrush}"
                            BorderBrush="{DynamicResource AccentMutedBrush}"
                            BorderThickness="1">
                        <Path Data="{StaticResource IconLogo}" Width="16" Height="16"
                              Fill="{DynamicResource AccentBrush}" Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="VisionEdit" Classes="h2" FontSize="15" LetterSpacing="-0.02" />
                        <Border Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentMutedBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="5,2"
                                HorizontalAlignment="Left">
                            <TextBlock Text="NEURAL STUDIO" Classes="brand-badge" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Center composer -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Border Classes="tool-pill" MinWidth="130">
                        <UniformGrid Columns="2">
                            <RadioButton Classes="tool-btn" Content="Box"
                                         IsChecked="{Binding SelectedTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Bounding Box'}"
                                         Command="{Binding SelectToolCommand}" CommandParameter="Bounding Box" />
                            <RadioButton Classes="tool-btn" Content="Text"
                                         IsChecked="{Binding SelectedTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Prompt'}"
                                         Command="{Binding SelectToolCommand}" CommandParameter="Prompt" />
                        </UniformGrid>
                    </Border>

                    <!-- PROMPT MODE: full composer with text input -->
                    <Border Classes="composer" Width="520"
                            IsVisible="{Binding SelectedTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Prompt'}">
                        <Grid ColumnDefinitions="Auto, *, Auto" Margin="2">
                            <Path Grid.Column="0" Classes="icon icon-tertiary" Data="{StaticResource IconSearch}"
                                  Width="14" Height="14" Margin="14,0,8,0" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding PromptText}"
                                     PlaceholderText="Describe what to segment…"
                                     FontSize="13" VerticalContentAlignment="Center" />
                            <Button Grid.Column="2"
                                    Command="{Binding SegmentCommand}"
                                    Classes="accent"
                                    CornerRadius="8"
                                    Padding="14,8"
                                    Margin="8,2,2,2"
                                    IsEnabled="{Binding CanRunSegment}"
                                    ToolTip.Tip="Run segmentation (Ctrl+Enter)">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Path Classes="icon" Data="{StaticResource IconBolt}" Width="13" Height="13" Stroke="{DynamicResource OnAccentTextBrush}" />
                                    <TextBlock Text="{Binding SegmentButtonText}" FontSize="11" FontWeight="Bold" LetterSpacing="0.08" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- BOX MODE: compact segment button only -->
                    <Button Classes="accent"
                            CornerRadius="10"
                            Padding="20,10"
                            Command="{Binding SegmentCommand}"
                            IsEnabled="{Binding CanRunSegment}"
                            IsVisible="{Binding SelectedTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Bounding Box'}"
                            ToolTip.Tip="Segment the drawn box (Ctrl+Enter)">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Path Classes="icon" Data="{StaticResource IconBolt}" Width="14" Height="14" Stroke="{DynamicResource OnAccentTextBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SegmentButtonText}" FontSize="12" FontWeight="Bold" LetterSpacing="0.06" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right utilities -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border Classes="status-pill" VerticalAlignment="Center" IsVisible="{Binding IsConnected}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Online" Classes="label-strong" FontSize="11"
                                       Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Classes="status-pill-muted" VerticalAlignment="Center"
                            IsVisible="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <Ellipse Width="6" Height="6" Fill="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Offline" Classes="label-strong" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding CheckConnectionCommand}"
                            Classes="ghost" Padding="12,7"
                            IsEnabled="{Binding CanRunConnectionCheck}"
                            FontSize="11"
                            ToolTip.Tip="Test server connection">
                        <TextBlock Text="{Binding ConnectionButtonText}" LetterSpacing="0.05" />
                    </Button>

                    <Button Command="{Binding SelectRightPanelTabCommand}"
                            CommandParameter="Server"
                            Classes="icon-button"
                            ToolTip.Tip="Server settings">
                        <Path Classes="icon icon-muted" Data="{StaticResource IconServer}" Width="16" Height="16" />
                    </Button>

                    <Button Command="{Binding ResetAllCommand}" Classes="icon-button" ToolTip.Tip="Reset entire project">
                        <Path Classes="icon icon-muted" Data="{StaticResource IconReset}" Width="16" Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================================================================
             ZONE 2 · WORKSPACE
             Left effect selector | Full-height canvas | Right context dock
             ================================================================ -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" Margin="14,12,14,10" ColumnSpacing="12">

            <!-- ============================================================
                 LEFT PANEL · EFFECTS LIBRARY (collapsible)
                 ============================================================ -->
            <Border Grid.Column="0"
                    Classes="app-panel"
                    Width="{Binding IsLeftPanelExpanded, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter='260,52'}">

                <Grid RowDefinitions="Auto, *, Auto">

                    <!-- Expanded header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto"
                          Margin="14,12,10,10"
                          IsVisible="{Binding IsLeftPanelExpanded}">
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="EFFECTS" Classes="h3" />
                            <TextBlock Text="{Binding SelectedEffect}" Classes="label-strong" FontSize="12" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleLeftPanelCommand}"
                                Classes="icon-button"
                                Width="28" Height="28"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Collapse">
                            <Path Classes="icon icon-muted" Data="{StaticResource IconChevronLeft}" Width="13" Height="13" />
                        </Button>
                    </Grid>

                    <!-- Collapsed rail header -->
                    <Button Grid.Row="0"
                            Command="{Binding ToggleLeftPanelCommand}"
                            Classes="icon-button panel-rail-btn"
                            IsVisible="{Binding IsLeftPanelExpanded, Converter={StaticResource InverseBoolConverter}}"
                            ToolTip.Tip="Expand effects">
                        <Path Classes="icon icon-muted" Data="{StaticResource IconChevronRight}" Width="13" Height="13" />
                    </Button>

                    <!-- Collapsed rail: full effect picker -->
                    <ScrollViewer Grid.Row="1"
                                  IsVisible="{Binding IsLeftPanelExpanded, Converter={StaticResource InverseBoolConverter}}"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Hidden"
                                  Padding="0,4,0,4">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <RadioButton Classes="effect-rail-btn"
                                         ToolTip.Tip="Color Grading"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Color Grading"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Color Grading'}">
                                <Path Classes="icon" Data="{StaticResource IconPalette}" Width="16" Height="16" />
                            </RadioButton>
                            <RadioButton Classes="effect-rail-btn"
                                         ToolTip.Tip="Grayscale"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Grayscale"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Grayscale'}">
                                <Path Classes="icon" Data="{StaticResource IconHalf}" Width="16" Height="16" />
                            </RadioButton>
                            <Border Width="20" Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,4" />
                            <RadioButton Classes="effect-rail-btn"
                                         ToolTip.Tip="Artistic Style"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Artistic Style"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Artistic Style'}">
                                <Path Classes="icon" Data="{StaticResource IconBrush}" Width="16" Height="16" />
                            </RadioButton>
                            <RadioButton Classes="effect-rail-btn"
                                         ToolTip.Tip="Sticker Generation"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Sticker Generation"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Sticker Generation'}">
                                <Path Classes="icon" Data="{StaticResource IconBadge}" Width="16" Height="16" />
                            </RadioButton>
                            <Border Width="20" Height="1" Background="{DynamicResource BorderSubtleBrush}" Margin="0,4" />
                            <RadioButton Classes="effect-rail-btn"
                                         ToolTip.Tip="Pixelation &amp; Blur"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Pixelation &amp; Blur"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Pixelation &amp; Blur'}">
                                <Path Classes="icon" Data="{StaticResource IconPixelate}" Width="16" Height="16" />
                            </RadioButton>
                            <RadioButton Classes="effect-rail-btn"
                                         ToolTip.Tip="Portrait Effect"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Portrait Effect"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Portrait Effect'}">
                                <Path Classes="icon" Data="{StaticResource IconPortrait}" Width="16" Height="16" />
                            </RadioButton>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Effect list -->
                    <ScrollViewer Grid.Row="1" Padding="10,0,10,8"
                                  IsVisible="{Binding IsLeftPanelExpanded}"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="4">

                            <TextBlock Text="Adjust" Classes="section-title" Margin="6,4,0,8" />

                            <RadioButton Classes="effect-card"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Color Grading"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Color Grading'}">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Width="28" Height="28" CornerRadius="8"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconPalette}" Width="14" Height="14" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="11,0,0,0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Classes="effect-name" Text="Color Grading" FontSize="12.5" FontWeight="SemiBold" />
                                        <TextBlock Text="Tint, brightness, contrast" Classes="label" FontSize="10" Opacity="0.75" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton Classes="effect-card"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Grayscale"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Grayscale'}">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Width="28" Height="28" CornerRadius="8"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconHalf}" Width="14" Height="14" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="11,0,0,0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Classes="effect-name" Text="Grayscale" FontSize="12.5" FontWeight="SemiBold" />
                                        <TextBlock Text="Desaturate target region" Classes="label" FontSize="10" Opacity="0.75" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <TextBlock Text="Stylize" Classes="section-title" />

                            <RadioButton Classes="effect-card"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Artistic Style"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Artistic Style'}">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Width="28" Height="28" CornerRadius="8"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconBrush}" Width="14" Height="14" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="11,0,0,0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Classes="effect-name" Text="Artistic Style" FontSize="12.5" FontWeight="SemiBold" />
                                        <TextBlock Text="Stylize or pencil render" Classes="label" FontSize="10" Opacity="0.75" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton Classes="effect-card"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Sticker Generation"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Sticker Generation'}">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Width="28" Height="28" CornerRadius="8"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconBadge}" Width="14" Height="14" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="11,0,0,0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Classes="effect-name" Text="Sticker" FontSize="12.5" FontWeight="SemiBold" />
                                        <TextBlock Text="Border, shadow, background" Classes="label" FontSize="10" Opacity="0.75" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <TextBlock Text="Mask Tools" Classes="section-title" />

                            <RadioButton Classes="effect-card"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Pixelation &amp; Blur"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Pixelation &amp; Blur'}">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Width="28" Height="28" CornerRadius="8"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconPixelate}" Width="14" Height="14" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="11,0,0,0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Classes="effect-name" Text="Pixelate / Blur" FontSize="12.5" FontWeight="SemiBold" />
                                        <TextBlock Text="Targeted privacy edits" Classes="label" FontSize="10" Opacity="0.75" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                            <RadioButton Classes="effect-card"
                                         Command="{Binding SelectEffectCommand}" CommandParameter="Portrait Effect"
                                         IsChecked="{Binding SelectedEffect, Mode=OneWay, Converter={StaticResource EnumToBoolConverter},ConverterParameter='Portrait Effect'}">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Width="28" Height="28" CornerRadius="8"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconPortrait}" Width="14" Height="14" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="11,0,0,0" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Classes="effect-name" Text="Portrait" FontSize="12.5" FontWeight="SemiBold" />
                                        <TextBlock Text="Background blur + feather" Classes="label" FontSize="10" Opacity="0.75" />
                                    </StackPanel>
                                </Grid>
                            </RadioButton>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Collapsed footer: icon-only Open New Image -->
                    <Button Grid.Row="2"
                            Command="{Binding OpenImageCommand}"
                            CommandParameter="{Binding $parent[Window]}"
                            Classes="icon-button panel-rail-btn"
                            Margin="0,4,0,12"
                            ToolTip.Tip="Open new image (Ctrl+O)"
                            IsVisible="{Binding IsLeftPanelExpanded, Converter={StaticResource InverseBoolConverter}}">
                        <Path Classes="icon icon-accent" Data="{StaticResource IconImport}" Width="14" Height="14" />
                    </Button>

                    <!-- Footer: Open New / Export -->
                    <StackPanel Grid.Row="2" Spacing="6" Margin="12,8,12,14"
                                IsVisible="{Binding IsLeftPanelExpanded}">
                        <Button Command="{Binding OpenImageCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                Classes="primary"
                                HorizontalAlignment="Stretch"
                                Height="40">
                            <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Grid.Column="0" Width="13" Height="13" VerticalAlignment="Center" Stretch="Uniform">
                                    <Path Classes="icon" Data="{StaticResource IconImport}" Stroke="White" />
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="Open New Image" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button Command="{Binding SaveImageCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                Classes="ghost"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                IsEnabled="{Binding CanSaveImage}">
                            <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Grid.Column="0" Width="13" Height="13" VerticalAlignment="Center" Stretch="Uniform">
                                    <Path Classes="icon icon-muted" Data="{StaticResource IconExport}" />
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="Export" FontSize="12" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================================
                 CENTER · CANVAS (full height — no bottom inspector)
                 ============================================================ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource CanvasSurfaceBrush}"
                    CornerRadius="16"
                    ClipToBounds="True"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="1"
                    BoxShadow="inset 0 0 40 0 #000000C0">
                <Panel>

                    <!-- Accent rail when image loaded -->
                    <Border Height="2" VerticalAlignment="Top" IsVisible="{Binding HasImage}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                <GradientStop Color="#00000000" Offset="0" />
                                <GradientStop Color="#22D3EE" Offset="0.5" />
                                <GradientStop Color="#00000000" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Loading rail -->
                    <ProgressBar VerticalAlignment="Top"
                                 IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Classes="loading" />

                    <!-- Image canvas -->
                    <controls:ImageCanvas
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        OriginalImage="{Binding CurrentImage}"
                        ProcessedImage="{Binding ProcessedImage}"
                        Mode="{Binding CanvasMode}"
                        Boxes="{Binding Boxes}"
                        Masks="{Binding Masks}"
                        HideMasks="{Binding AreMasksHidden}"
                        MaskVisibility="{Binding MaskVisibilityStates}"
                        IsCompareMode="{Binding IsCompareMode}" />

                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                                IsVisible="{Binding CurrentImage, Converter={x:Static ObjectConverters.IsNull}}">
                        <Border Width="72" Height="72" CornerRadius="16"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1">
                            <Path Data="{StaticResource IconImage}" Width="28" Height="28"
                                  Stroke="{DynamicResource AccentBrush}"
                                  StrokeThickness="1.6"
                                  StrokeLineCap="Round"
                                  Stretch="Uniform"
                                  Fill="Transparent" />
                        </Border>
                        <StackPanel Spacing="4">
                            <TextBlock Text="No image loaded" Classes="h1" FontSize="16" HorizontalAlignment="Center" />
                            <TextBlock Text="Import an image to segment regions and apply effects."
                                       Classes="label" MaxWidth="340" TextAlignment="Center"
                                       TextWrapping="Wrap" FontSize="11" Opacity="0.85" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                            <Button Command="{Binding OpenImageCommand}"
                                    CommandParameter="{Binding $parent[Window]}"
                                    Classes="primary">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Path Classes="icon" Data="{StaticResource IconImport}" Width="13" Height="13" Stroke="White" />
                                    <TextBlock Text="Import Image" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CheckConnectionCommand}"
                                    Classes="ghost"
                                    IsEnabled="{Binding CanRunConnectionCheck}">
                                <TextBlock Text="Check Server" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Floating canvas toolbar (top-right) -->
                    <Border Classes="canvas-toolbar"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Margin="0,14,14,0"
                            IsVisible="{Binding HasImage}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Button Command="{Binding ToggleCompareCommand}"
                                    Classes="toolbar-btn"
                                    Classes.active="{Binding IsCompareMode}"
                                    ToolTip.Tip="Compare original vs result">
                                <Path Classes="icon-toolbar" Data="{StaticResource IconCompare}" Width="15" Height="15" />
                            </Button>
                            <Button Command="{Binding ToggleHideMasksCommand}"
                                    Classes="toolbar-btn"
                                    IsEnabled="{Binding MaskItems.Count, Converter={StaticResource CollectionCountToBoolConverter}}"
                                    ToolTip.Tip="Show or hide mask overlays">
                                <Panel Width="15" Height="15">
                                    <Path Classes="icon-toolbar" Data="{StaticResource IconVisibility}" Width="15" Height="15"
                                          IsVisible="{Binding AreMasksHidden, Converter={StaticResource InverseBoolConverter}}" />
                                    <Path Classes="icon-toolbar" Data="{StaticResource IconVisibilityOff}" Width="15" Height="15"
                                          IsVisible="{Binding AreMasksHidden}" />
                                </Panel>
                            </Button>
                            <Button Command="{Binding UndoEffectCommand}"
                                    Classes="toolbar-btn"
                                    IsEnabled="{Binding CanUndoEffect}"
                                    ToolTip.Tip="Undo last effect (Ctrl+Z)">
                                <Path Classes="icon-toolbar" Data="{StaticResource IconUndo}" Width="15" Height="15" />
                            </Button>
                            <Border Classes="canvas-toolbar-divider" />
                            <Button Command="{Binding ClearMasksCommand}"
                                    Classes="toolbar-btn danger"
                                    IsEnabled="{Binding CanClearWorkspace}"
                                    ToolTip.Tip="Clear all masks (Esc)">
                                <Path Classes="icon-toolbar" Data="{StaticResource IconClear}" Width="15" Height="15" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Compare badge -->
                    <Border Classes="compare-badge"
                            IsVisible="{Binding IsCompareMode}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Center">
                        <TextBlock Text="◧  ORIGINAL REFERENCE" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource OnAccentTextBrush}" LetterSpacing="0.1" />
                    </Border>

                    <!-- Neural processing HUD -->
                    <Border IsVisible="{Binding IsLoading}"
                            Background="{DynamicResource CanvasOverlayBrush}"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18">
                            <Border Width="76" Height="76" CornerRadius="20"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                    BoxShadow="0 0 32 0 #4022D3EE">
                                <Path Data="{StaticResource IconSpark}" Width="32" Height="32"
                                      Fill="{DynamicResource AccentBrush}" Stretch="Uniform" />
                            </Border>
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="Processing" Classes="h1" FontSize="16" HorizontalAlignment="Center" />
                                <TextBlock Text="Running neural segmentation" Classes="label" HorizontalAlignment="Center" FontSize="11" />
                            </StackPanel>
                            <ProgressBar IsIndeterminate="True" Width="180" Classes="loading" />
                        </StackPanel>
                    </Border>
                </Panel>
            </Border>

            <!-- ============================================================
                 RIGHT PANEL · CONTEXT DOCK
                 Tabs: ADJUST (effect params) | LAYERS (masks + history) | SERVER
                 ============================================================ -->
            <Border Grid.Column="2"
                    Classes="app-panel"
                    Width="{Binding IsRightPanelExpanded, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter='360,52'}">

                <Grid RowDefinitions="Auto, Auto, *">

                    <!-- ——— EXPANDED STATE ——— -->

                    <!-- Header (expanded) -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto"
                          Margin="14,12,10,8"
                          IsVisible="{Binding IsRightPanelExpanded}">
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding RightPanelHeaderTitle}" Classes="h3" />
                            <TextBlock Text="{Binding RightPanelSubtitle}" Classes="label-strong" FontSize="12" />
                        </StackPanel>
                        <!-- Mask count badge (LAYERS tab) -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource AccentSoftBrush}"
                                BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1"
                                CornerRadius="999" Padding="9,3" VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                IsVisible="{Binding IsLayersTab}">
                            <TextBlock Text="{Binding MaskItems.Count}" Classes="mono-accent" FontSize="11" />
                        </Border>
                        <!-- Connection dot (SERVER tab) -->
                        <Ellipse Grid.Column="1" Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,10,0"
                                 Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}, ConverterParameter=status}"
                                 IsVisible="{Binding IsServerTab}" />
                        <Button Grid.Column="2"
                                Command="{Binding ToggleRightPanelCommand}"
                                Classes="icon-button"
                                Width="28" Height="28"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Collapse panel">
                            <Path Classes="icon icon-muted" Data="{StaticResource IconChevronRight}" Width="13" Height="13" />
                        </Button>
                    </Grid>

                    <!-- Tab strip (expanded) -->
                    <Border Grid.Row="1"
                            Classes="tool-pill"
                            Margin="10,0,10,10"
                            IsVisible="{Binding IsRightPanelExpanded}">
                        <UniformGrid Columns="4">
                            <RadioButton Classes="panel-tab" Content="Adjust"
                                         IsChecked="{Binding RightPanelTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=0, Mode=TwoWay}" />
                            <RadioButton Classes="panel-tab" Content="Layers"
                                         IsChecked="{Binding RightPanelTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=1, Mode=TwoWay}" />
                            <RadioButton Classes="panel-tab" Content="History"
                                         IsChecked="{Binding RightPanelTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=2, Mode=TwoWay}" />
                            <RadioButton Classes="panel-tab" Content="Server"
                                         IsChecked="{Binding RightPanelTabIndex, Converter={StaticResource IntEqualsConverter}, ConverterParameter=3, Mode=TwoWay}" />
                        </UniformGrid>
                    </Border>

                    <!-- ——— COLLAPSED STATE ——— -->

                    <!-- Collapsed: expand chevron -->
                    <Button Grid.Row="0"
                            Command="{Binding ToggleRightPanelCommand}"
                            Classes="icon-button panel-rail-btn"
                            IsVisible="{Binding IsRightPanelExpanded, Converter={StaticResource InverseBoolConverter}}"
                            ToolTip.Tip="Expand panel">
                        <Path Classes="icon icon-muted" Data="{StaticResource IconChevronLeft}" Width="13" Height="13" />
                    </Button>

                    <!-- Collapsed: icon shortcuts -->
                    <StackPanel Grid.Row="1"
                                Spacing="8"
                                HorizontalAlignment="Center"
                                Margin="0,4,0,0"
                                IsVisible="{Binding IsRightPanelExpanded, Converter={StaticResource InverseBoolConverter}}">
                        <Button Command="{Binding SelectRightPanelTabCommand}" CommandParameter="Adjust"
                                Classes="icon-button" Width="28" Height="28" ToolTip.Tip="Adjust parameters">
                            <Path Classes="icon icon-muted" Data="{StaticResource IconSliders}" Width="14" Height="14" />
                        </Button>
                        <Button Command="{Binding SelectRightPanelTabCommand}" CommandParameter="Layers"
                                Classes="icon-button" Width="28" Height="28" ToolTip.Tip="Layers">
                            <Path Classes="icon icon-muted" Data="{StaticResource IconLayers}" Width="14" Height="14" />
                        </Button>
                        <Button Command="{Binding SelectRightPanelTabCommand}" CommandParameter="History"
                                Classes="icon-button" Width="28" Height="28" ToolTip.Tip="History">
                            <Path Classes="icon icon-muted" Data="{StaticResource IconHistory}" Width="14" Height="14" />
                        </Button>
                        <Button Command="{Binding SelectRightPanelTabCommand}" CommandParameter="Server"
                                Classes="icon-button" Width="28" Height="28" ToolTip.Tip="Server">
                            <Path Classes="icon icon-muted" Data="{StaticResource IconServer}" Width="14" Height="14" />
                        </Button>
                    </StackPanel>

                    <!-- ——— TAB CONTENT ——— -->
                    <Grid Grid.Row="2" IsVisible="{Binding IsRightPanelExpanded}">

                        <!-- =============================================
                             TAB 0 · ADJUST — Sticky header + param cards
                             ============================================= -->
                        <Grid IsVisible="{Binding IsAdjustTab}" RowDefinitions="Auto, *, Auto">

                            <!-- Sticky effect header (visible when image loaded) -->
                            <Border Grid.Row="0" Classes="adjust-header"
                                    IsVisible="{Binding HasImage}">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="{DynamicResource AccentSoftBrush}"
                                            BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <Path Classes="icon icon-accent" Data="{StaticResource IconSliders}" Width="16" Height="16" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedEffect}"
                                                   FontSize="13.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="Adjust parameters" Classes="h3" FontSize="10" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding ApplyEffectCommand}"
                                            Classes="action-primary"
                                            IsEnabled="{Binding CanApplyEffects}"
                                            VerticalAlignment="Center"
                                            Height="34"
                                            Padding="16,0">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <Path Classes="icon" Data="{StaticResource IconApply}"
                                                  Width="12" Height="12"
                                                  Stroke="{DynamicResource OnAccentTextBrush}" />
                                            <TextBlock Text="Apply" FontSize="12" FontWeight="Bold" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Content: empty state or scrollable params -->
                            <Panel Grid.Row="1">

                                <!-- Empty: no image loaded -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14"
                                            Margin="24"
                                            IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}">
                                    <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Center"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Path Classes="icon icon-tertiary" Data="{StaticResource IconSliders}" Width="22" Height="22" />
                                    </Border>
                                    <TextBlock Text="No image loaded" Classes="h2" HorizontalAlignment="Center" />
                                    <TextBlock Text="Import an image to adjust effect parameters."
                                               Classes="label" MaxWidth="240" TextAlignment="Center"
                                               TextWrapping="Wrap" FontSize="11" />
                                </StackPanel>

                                <!-- Parameters wrapped in cards -->
                                <ScrollViewer IsVisible="{Binding HasImage}"
                                              Padding="12,12,12,4"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel Spacing="0">

                                        <!-- COLOR GRADING -->
                                        <StackPanel Spacing="0"
                                                    IsVisible="{Binding SelectedEffect, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Color Grading'}">
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Target" Classes="h3" />
                                                    <Border Classes="tool-pill">
                                                        <UniformGrid Columns="2">
                                                            <RadioButton Classes="tool-btn" Content="Foreground" IsChecked="{Binding CgIsForeground}" />
                                                            <RadioButton Classes="tool-btn" Content="Background" IsChecked="{Binding CgIsForeground, Converter={StaticResource InverseBoolConverter}}" />
                                                        </UniformGrid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Tint Color" Classes="h3" />
                                                    <Button Classes="color-button">
                                                        <Button.Flyout>
                                                            <Flyout Placement="Bottom">
                                                                <Border Classes="flyout-panel" Padding="8">
                                                                    <cp:ColorView Color="{Binding CgTintColor, Mode=TwoWay}" />
                                                                </Border>
                                                            </Flyout>
                                                        </Button.Flyout>
                                                        <Grid ColumnDefinitions="*, Auto">
                                                            <Border Classes="color-fill"
                                                                    Background="{Binding CgTintColor, Converter={StaticResource ColorToBrushConverter}}" />
                                                            <Path Grid.Column="1" Classes="icon icon-muted"
                                                                  Data="{StaticResource IconChevronDown}"
                                                                  Width="14" Height="14"
                                                                  Margin="0,0,12,0"
                                                                  VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Tint Mix" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding CgTintStrength, StringFormat={}{0:P0}}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="0" Maximum="1" Value="{Binding CgTintStrength}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Brightness" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding CgBrightness}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="-100" Maximum="100" Value="{Binding CgBrightness}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Contrast" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding CgContrast}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="1" Maximum="30" Value="{Binding CgContrast}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- GRAYSCALE -->
                                        <StackPanel Spacing="0"
                                                    IsVisible="{Binding SelectedEffect, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Grayscale'}">
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Target" Classes="h3" />
                                                    <Border Classes="tool-pill">
                                                        <UniformGrid Columns="2">
                                                            <RadioButton Classes="tool-btn" Content="Foreground" IsChecked="{Binding GsIsForeground}" />
                                                            <RadioButton Classes="tool-btn" Content="Background" IsChecked="{Binding GsIsForeground, Converter={StaticResource InverseBoolConverter}}" />
                                                        </UniformGrid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- ARTISTIC STYLE -->
                                        <StackPanel Spacing="0"
                                                    IsVisible="{Binding SelectedEffect, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Artistic Style'}">
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Mode" Classes="h3" />
                                                    <Border Classes="tool-pill">
                                                        <UniformGrid Columns="2">
                                                            <RadioButton Classes="tool-btn" Content="Stylize" IsChecked="{Binding ArtIsStylize}" />
                                                            <RadioButton Classes="tool-btn" Content="Pencil" IsChecked="{Binding ArtIsStylize, Converter={StaticResource InverseBoolConverter}}" />
                                                        </UniformGrid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Sigma S" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ArtSigmaS}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="1" Maximum="200" Value="{Binding ArtSigmaS}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Sigma R" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ArtSigmaR}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="1" Maximum="100" Value="{Binding ArtSigmaR}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Shade Factor" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ArtShadeFactor}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="1" Maximum="100" Value="{Binding ArtShadeFactor}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- STICKER GENERATION -->
                                        <StackPanel Spacing="0"
                                                    IsVisible="{Binding SelectedEffect, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Sticker Generation'}">
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Scale" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding StScale}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="1" Maximum="50" Value="{Binding StScale}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Rotation" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding StRotation}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="-180" Maximum="180" Value="{Binding StRotation}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Border Color" Classes="h3" />
                                                    <Button Classes="color-button">
                                                        <Button.Flyout>
                                                            <Flyout Placement="Bottom">
                                                                <Border Classes="flyout-panel" Padding="8">
                                                                    <cp:ColorView Color="{Binding StBorderColor, Mode=TwoWay}" />
                                                                </Border>
                                                            </Flyout>
                                                        </Button.Flyout>
                                                        <Grid ColumnDefinitions="*, Auto">
                                                            <Border Classes="color-fill"
                                                                    Background="{Binding StBorderColor, Converter={StaticResource ColorToBrushConverter}}" />
                                                            <Path Grid.Column="1" Classes="icon icon-muted"
                                                                  Data="{StaticResource IconChevronDown}"
                                                                  Width="14" Height="14"
                                                                  Margin="0,0,12,0"
                                                                  VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Thickness" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding StThickness}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="1" Maximum="30" Value="{Binding StThickness}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Shadow Blur" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding StShadowBlur}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="0" Maximum="100" Value="{Binding StShadowBlur}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group" Padding="10">
                                                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" ColumnSpacing="12" RowSpacing="6">
                                                    <!-- Column 0: Type -->
                                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="6">
                                                        <TextBlock Text="Background Type" Classes="h3" FontSize="10" />
                                                        <ComboBox SelectedIndex="{Binding StBackgroundMode}"
                                                                  HorizontalAlignment="Stretch" Height="30">
                                                            <ComboBoxItem Content="Original" />
                                                            <ComboBoxItem Content="Solid Color" />
                                                            <ComboBoxItem Content="Image File" />
                                                            <ComboBoxItem Content="Transparent" />
                                                        </ComboBox>
                                                    </StackPanel>

                                                    <!-- Column 1: Settings -->
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6" VerticalAlignment="Bottom">
                                                        <TextBlock Text="Settings" Classes="h3" FontSize="10" 
                                                                   IsVisible="{Binding StBackgroundMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='1,2'}" />
                                                        
                                                        <!-- Solid Color Picker -->
                                                        <Button Classes="color-button" IsVisible="{Binding StShowSolidBackground}" Height="30">
                                                            <Button.Flyout>
                                                                <Flyout Placement="Bottom">
                                                                    <Border Classes="flyout-panel" Padding="8">
                                                                        <cp:ColorView Color="{Binding StBackgroundColor, Mode=TwoWay}" />
                                                                    </Border>
                                                                </Flyout>
                                                            </Button.Flyout>
                                                            <Grid ColumnDefinitions="*, Auto">
                                                                <Border Classes="color-fill"
                                                                        Background="{Binding StBackgroundColor, Converter={StaticResource ColorToBrushConverter}}" />
                                                                <Path Grid.Column="1" Classes="icon icon-muted"
                                                                      Data="{StaticResource IconChevronDown}"
                                                                      Width="12" Height="12"
                                                                      Margin="0,0,10,0"
                                                                      VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Button>

                                                        <!-- Image Picker -->
                                                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="6"
                                                              IsVisible="{Binding StShowImageBackground}">
                                                            <Button Grid.Column="0"
                                                                    Command="{Binding PickStickerBackgroundCommand}"
                                                                    CommandParameter="{Binding $parent[Window]}"
                                                                    Classes="ghost" Height="30" Padding="12,0">
                                                                <Path Classes="icon icon-muted" Data="{StaticResource IconImport}" Width="12" Height="12" />
                                                            </Button>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding StickerBackgroundFileName}"
                                                                       Classes="label" FontSize="9"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- PIXELATION & BLUR -->
                                        <StackPanel Spacing="0"
                                                    IsVisible="{Binding SelectedEffect, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Pixelation &amp; Blur'}">
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Mode" Classes="h3" />
                                                    <Border Classes="tool-pill">
                                                        <UniformGrid Columns="2">
                                                            <RadioButton Classes="tool-btn" Content="Pixelate" IsChecked="{Binding PbIsPixelate}" />
                                                            <RadioButton Classes="tool-btn" Content="Blur" IsChecked="{Binding PbIsPixelate, Converter={StaticResource InverseBoolConverter}}" />
                                                        </UniformGrid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="Target" Classes="h3" />
                                                    <Border Classes="tool-pill">
                                                        <UniformGrid Columns="2">
                                                            <RadioButton Classes="tool-btn" Content="Foreground" IsChecked="{Binding PbIsForeground}" />
                                                            <RadioButton Classes="tool-btn" Content="Background" IsChecked="{Binding PbIsForeground, Converter={StaticResource InverseBoolConverter}}" />
                                                        </UniformGrid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Intensity" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding PbIntensity}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="1" Maximum="100" Value="{Binding PbIntensity}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- PORTRAIT EFFECT -->
                                        <StackPanel Spacing="0"
                                                    IsVisible="{Binding SelectedEffect, Converter={StaticResource EnumToBoolConverter}, ConverterParameter='Portrait Effect'}">
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Blur Strength" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding PtBlurStrength}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="3" Maximum="501" Value="{Binding PtBlurStrength}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Classes="param-group">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <TextBlock Text="Feather Edge" Classes="h3" />
                                                        <TextBlock Grid.Column="1" Text="{Binding PtFeatherAmount}" Classes="mono-accent" />
                                                    </Grid>
                                                    <Slider Minimum="0" Maximum="501" Value="{Binding PtFeatherAmount}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                    </StackPanel>
                                </ScrollViewer>
                            </Panel>

                            <!-- Footer: reset + mask count -->
                            <Border Grid.Row="2" IsVisible="{Binding HasImage}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="14,10">
                                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                                    <Button Grid.Column="0"
                                            Command="{Binding ResetEffectCommand}"
                                            Classes="icon-button"
                                            Width="36" Height="36"
                                            ToolTip.Tip="Undo last applied effect (Ctrl+Z)">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconReset}" Width="15" Height="15" />
                                    </Button>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                                                VerticalAlignment="Center">
                                        <Path Classes="icon icon-tertiary" Data="{StaticResource IconLayers}"
                                              Width="11" Height="11" VerticalAlignment="Center" />
                                        <TextBlock Classes="footer-text" VerticalAlignment="Center"
                                                   IsVisible="{Binding HasMasks}">
                                            <Run Text="{Binding MaskItems.Count}" /><Run Text=" masks" />
                                        </TextBlock>
                                        <TextBlock Text="No masks" Classes="footer-text"
                                                   IsVisible="{Binding HasMasks, Converter={StaticResource InverseBoolConverter}}"
                                                   Opacity="0.5" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </Grid>

                        <!-- =============================================
                             TAB 1 · LAYERS — Masks + History
                             ============================================= -->
                        <Grid IsVisible="{Binding IsLayersTab}" RowDefinitions="*, Auto">

                            <ScrollViewer Grid.Row="0"
                                          Padding="10,4,10,10"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="0">

                                    <!-- Masks: empty state -->
                                    <StackPanel Spacing="12"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="16,20,16,0"
                                                IsVisible="{Binding MaskItems.Count, Converter={StaticResource CollectionCountToBoolConverter}, ConverterParameter='invert'}">
                                        <Border Width="48" Height="48" CornerRadius="14" HorizontalAlignment="Center"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <Path Classes="icon icon-tertiary" Data="{StaticResource IconLayers}" Width="22" Height="22" />
                                        </Border>
                                        <TextBlock Text="No masks yet" Classes="h2" HorizontalAlignment="Center" />
                                        <TextBlock Text="Draw a box or enter a prompt, then Segment."
                                                   Classes="label" MaxWidth="220" TextAlignment="Center"
                                                   TextWrapping="Wrap" FontSize="11" />
                                    </StackPanel>

                                    <!-- Masks: list -->
                                    <ListBox ItemsSource="{Binding MaskItems}"
                                             SelectedIndex="{Binding SelectedMaskIndex}"
                                             Classes="mask-list"
                                             IsVisible="{Binding MaskItems.Count, Converter={StaticResource CollectionCountToBoolConverter}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="mask-card" Padding="12,10">
                                                    <Grid ColumnDefinitions="4, *, Auto" ColumnSpacing="12">
                                                        <Border Grid.Column="0" Classes="mask-stripe"
                                                                Background="{Binding Color, Converter={StaticResource ColorToBrushConverter}}" />
                                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                                                            <TextBlock Text="Neural segment" Classes="label" FontSize="10" />
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="2" IsChecked="{Binding IsVisible}"
                                                                  VerticalAlignment="Center"
                                                                  ToolTip.Tip="Toggle mask visibility" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- LAYERS footer: toggle mask visibility -->
                            <Border Grid.Row="1"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="12,12">
                                <Button Command="{Binding ToggleHideMasksCommand}"
                                        Classes="ghost"
                                        HorizontalAlignment="Stretch"
                                        Height="36"
                                        IsEnabled="{Binding MaskItems.Count, Converter={StaticResource CollectionCountToBoolConverter}}">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconVisibility}" Width="13" Height="13"
                                              IsVisible="{Binding AreMasksHidden, Converter={StaticResource InverseBoolConverter}}" />
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconVisibilityOff}" Width="13" Height="13"
                                              IsVisible="{Binding AreMasksHidden}" />
                                        <TextBlock Text="{Binding HideMasksButtonText}" FontSize="11" LetterSpacing="0.05" />
                                    </StackPanel>
                                </Button>
                            </Border>

                        </Grid>

                        <!-- =============================================
                             TAB 2 · HISTORY — Applied effects + undo
                             ============================================= -->
                        <Grid IsVisible="{Binding IsHistoryTab}" RowDefinitions="Auto, *, Auto">

                            <!-- Sticky "Undo Last" header -->
                            <Border Grid.Row="0" Classes="adjust-header"
                                    IsVisible="{Binding HasHistory}">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="{DynamicResource AccentSoftBrush}"
                                            BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <Path Classes="icon icon-accent" Data="{StaticResource IconHistory}" Width="16" Height="16" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LastHistoryStep}"
                                                   FontSize="13.5" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="Most recent step" Classes="h3" FontSize="10" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding UndoEffectCommand}"
                                            Classes="action-primary"
                                            VerticalAlignment="Center"
                                            Height="34"
                                            Padding="14,0"
                                            ToolTip.Tip="Undo last applied effect">
                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                            <Path Classes="icon" Data="{StaticResource IconUndo}"
                                                  Width="12" Height="12"
                                                  Stroke="{DynamicResource OnAccentTextBrush}" />
                                            <TextBlock Text="Undo" FontSize="12" FontWeight="Bold" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Body: history list or empty state -->
                            <Panel Grid.Row="1">

                                <!-- Empty state -->
                                <StackPanel Spacing="12"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="24,40"
                                            IsVisible="{Binding HasHistory, Converter={StaticResource InverseBoolConverter}}">
                                    <Border Width="56" Height="56" CornerRadius="16" HorizontalAlignment="Center"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Path Classes="icon icon-tertiary" Data="{StaticResource IconHistory}" Width="26" Height="26" />
                                    </Border>
                                    <TextBlock Text="No effects applied" Classes="h2" HorizontalAlignment="Center" />
                                    <TextBlock Text="Applied effects appear here so you can step back through your edits."
                                               Classes="label" MaxWidth="240" TextAlignment="Center"
                                               TextWrapping="Wrap" FontSize="11" />
                                </StackPanel>

                                <!-- History list (newest at top) -->
                                <ScrollViewer Padding="10,8,10,8"
                                              HorizontalScrollBarVisibility="Disabled"
                                              IsVisible="{Binding HasHistory}">
                                    <ItemsControl ItemsSource="{Binding History}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ReversibleStackPanel ReverseOrder="True" Spacing="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="history-row">
                                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                                        <Border Grid.Column="0"
                                                                Width="28" Height="28" CornerRadius="8"
                                                                Background="{DynamicResource AccentSoftBrush}"
                                                                BorderBrush="{DynamicResource AccentMutedBrush}"
                                                                BorderThickness="1"
                                                                VerticalAlignment="Center">
                                                            <Path Classes="icon icon-accent" Data="{StaticResource IconApply}"
                                                                  Width="12" Height="12" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding}"
                                                                       FontWeight="SemiBold" FontSize="13"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                                            <TextBlock Text="Applied effect" Classes="label" FontSize="10" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Panel>

                            <!-- Footer: Clear all history -->
                            <Border Grid.Row="2"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="12,12"
                                    IsVisible="{Binding HasHistory}">
                                <Button Command="{Binding ResetAllCommand}"
                                        Classes="ghost"
                                        HorizontalAlignment="Stretch"
                                        Height="36"
                                        ToolTip.Tip="Discard all applied effects and start fresh">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <Path Classes="icon icon-muted" Data="{StaticResource IconClear}" Width="13" Height="13" />
                                        <TextBlock Text="Clear All" FontSize="11" />
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>

                        <!-- =============================================
                             TAB 3 · SERVER — Connection settings
                             ============================================= -->
                        <ScrollViewer IsVisible="{Binding IsServerTab}" Padding="10,0,10,10">
                            <StackPanel Spacing="14">

                                <Border Classes="param-cell" Padding="14">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                        <Border Width="40" Height="40" CornerRadius="10"
                                                Background="{DynamicResource AccentSoftBrush}"
                                                BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1">
                                            <Path Classes="icon icon-accent" Data="{StaticResource IconServer}"
                                                  Width="18" Height="18" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="SAM3 API" FontWeight="SemiBold" FontSize="13" />
                                            <TextBlock Text="Segmentation backend" Classes="label" FontSize="10" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Classes="status-pill" VerticalAlignment="Center"
                                                IsVisible="{Binding IsConnected}">
                                            <TextBlock Text="Online" Classes="label-strong" FontSize="9"
                                                       Foreground="{DynamicResource SuccessBrush}" />
                                        </Border>
                                        <Border Grid.Column="2" Classes="status-pill-muted" VerticalAlignment="Center"
                                                IsVisible="{Binding IsConnected, Converter={StaticResource InverseBoolConverter}}">
                                            <TextBlock Text="Offline" Classes="label-strong" FontSize="9" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Endpoint URL" Classes="h3" Margin="2,0,0,0" />
                                    <Border Classes="url-input" HorizontalAlignment="Stretch">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Path Grid.Column="0" Classes="icon icon-tertiary"
                                                  Data="{StaticResource IconServer}"
                                                  Width="14" Height="14"
                                                  Margin="10,0,6,0"
                                                  VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding ServerUrl}"
                                                     PlaceholderText="https://your-server.example"
                                                     FontSize="12"
                                                     HorizontalAlignment="Stretch"
                                                     ClipToBounds="True" />
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="Full URL including scheme. Changes apply on connect."
                                               Classes="label" FontSize="10" TextWrapping="Wrap" Opacity="0.8" />
                                </StackPanel>

                                <Button Command="{Binding CheckConnectionCommand}"
                                        Classes="primary"
                                        HorizontalAlignment="Stretch"
                                        Height="40"
                                        IsEnabled="{Binding CanRunConnectionCheck}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Path Classes="icon" Data="{StaticResource IconBolt}" Width="13" Height="13" Stroke="White" />
                                        <TextBlock Text="{Binding ConnectionButtonText}" FontSize="11" LetterSpacing="0.06" />
                                    </StackPanel>
                                </Button>

                                <Border Classes="param-cell" Padding="12,10">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Status" Classes="h3" />
                                        <TextBlock Text="{Binding StatusMessage}"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}, ConverterParameter=status}" />
                                    </StackPanel>
                                </Border>

                                <!-- Auto-update card -->
                                <Border Classes="param-cell" Padding="14">
                                    <StackPanel Spacing="10">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Border Width="32" Height="32" CornerRadius="10"
                                                    Background="{DynamicResource AccentSoftBrush}"
                                                    BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1"
                                                    VerticalAlignment="Center">
                                                <Path Classes="icon icon-accent" Data="{StaticResource IconUpdate}" Width="15" Height="15" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="App Updates" Classes="h3" />
                                                <TextBlock Text="{Binding UpdateStatus}" FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Button Command="{Binding CheckForUpdatesCommand}"
                                                    Classes="ghost"
                                                    IsEnabled="{Binding CanCheckForUpdate}"
                                                    Padding="12,8" FontSize="11">
                                                <TextBlock Text="Check for Updates" />
                                            </Button>
                                            <Button Command="{Binding ApplyUpdateCommand}"
                                                    Classes="primary"
                                                    IsEnabled="{Binding CanInstallUpdate}"
                                                    IsVisible="{Binding IsUpdateAvailable}"
                                                    Padding="12,8" FontSize="11">
                                                <TextBlock Text="Restart &amp; Install" />
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                    <!-- End tab content -->

                </Grid>
            </Border>

        </Grid>

        <!-- ================================================================
             ZONE 3 · STATUS FOOTER
             ================================================================ -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                Padding="22,6,22,8">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">

                <!-- File info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Path Classes="icon icon-tertiary" Data="{StaticResource IconImage}" Width="11" Height="11" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ImageFileName}" Classes="footer-text" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="·" Classes="footer-text" VerticalAlignment="Center" IsVisible="{Binding HasImage}" />
                    <TextBlock Text="{Binding ImageDimensionsText}" Classes="footer-text"
                               IsVisible="{Binding HasImage}" VerticalAlignment="Center" />
                    <TextBlock Text="·" Classes="footer-text" VerticalAlignment="Center" IsVisible="{Binding HasImage}" />
                    <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding HasImage}">
                        <Path Classes="icon icon-tertiary" Data="{StaticResource IconLayers}" Width="11" Height="11" VerticalAlignment="Center" />
                        <TextBlock Classes="footer-text" VerticalAlignment="Center">
                            <Run Text="{Binding MaskItems.Count}" /><Run Text=" masks" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Status message -->
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Classes="footer-text"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="640"
                           Foreground="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}, ConverterParameter=status}" />

                <!-- Active effect + tool -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                             IsVisible="{Binding HasImage}" />
                    <TextBlock Text="{Binding SelectedEffect}" Classes="footer-text"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                               IsVisible="{Binding HasImage}" />
                    <TextBlock Text="·" Classes="footer-text" VerticalAlignment="Center" IsVisible="{Binding HasImage}" />
                    <TextBlock Text="{Binding SelectedTool}" Classes="footer-text" VerticalAlignment="Center" />
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</UserControl>
