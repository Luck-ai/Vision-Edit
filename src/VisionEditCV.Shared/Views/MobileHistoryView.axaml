<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VisionEditCV.Shared.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="430" d:DesignHeight="852"
             x:Class="VisionEditCV.Shared.Views.MobileHistoryView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel"
             Background="{DynamicResource AppBackgroundBrush}">

  <Grid RowDefinitions="Auto, *">

    <Border Grid.Row="0" Classes="top-bar" Padding="16,12">
      <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Width="30" Height="30" CornerRadius="8"
                  Background="{DynamicResource AccentSoftBrush}"
                  BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1">
            <Path Data="{StaticResource IconLogo}" Width="14" Height="14"
                  Fill="{DynamicResource AccentBrush}" Stretch="Uniform"
                  HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="VisionEdit" Classes="h2" FontSize="14" VerticalAlignment="Center" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
          <Button Classes="icon-button" Width="34" Height="34" ToolTip.Tip="Filter">
            <Path Data="M3,6 L21,6 M6,12 L18,12 M10,18 L14,18" Width="15" Height="15"
                  Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.8" Stretch="Uniform" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto" Padding="0,0,0,110">
      <StackPanel Margin="18,18,18,0" Spacing="14">

        <StackPanel Spacing="6">
          <TextBlock Text="TODAY · 48 ACTIONS" Classes="mono"
                     FontSize="10" LetterSpacing="0.16"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
          <Grid ColumnDefinitions="*, Auto">
            <TextBlock Grid.Column="0" Text="History" FontSize="30" FontWeight="Bold"
                       LetterSpacing="-0.025"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <Button Grid.Column="1" Classes="ghost" Height="32" Padding="14,0" VerticalAlignment="Bottom"
                    Command="{Binding UndoEffectCommand}" IsEnabled="{Binding CanUndoEffect}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Path Data="{StaticResource IconUndo}" Width="13" Height="13"
                      Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.8" Stretch="Uniform" />
                <TextBlock Text="Undo" FontSize="11" FontWeight="SemiBold" />
              </StackPanel>
            </Button>
          </Grid>
        </StackPanel>

        <TextBlock Text="TODAY" Classes="mono" FontSize="9.5" LetterSpacing="0.14"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,12,0,0" />

        <ItemsControl ItemsSource="{Binding History}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="8" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="{DynamicResource SurfaceBrush}"
                      BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                      CornerRadius="10" Padding="12">
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="11">
                  <Border Grid.Column="0" Width="32" Height="32" CornerRadius="9"
                          Background="{DynamicResource AccentSoftBrush}"
                          BorderBrush="{DynamicResource AccentMutedBrush}" BorderThickness="1">
                    <Path Data="{StaticResource IconSpark}" Width="14" Height="14"
                          Fill="{DynamicResource AccentBrush}" Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding}" FontSize="13" FontWeight="SemiBold"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Grid.Column="2" Text="now" Classes="mono" FontSize="10"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border IsVisible="{Binding !HasHistory}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                CornerRadius="12" Padding="24" HorizontalAlignment="Stretch">
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconHistory}" Width="24" Height="24"
                  Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.8" Stretch="Uniform" />
            <TextBlock Text="No history yet" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Open a project and apply effects to see actions here."
                       FontSize="12" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="280"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
